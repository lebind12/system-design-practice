# 이 파일은 url-shortener 챕터에서 사용하는 환경 변수의 구조를 보여주는 공개 템플릿이다.
# 실제 값은 `cp .env.example .env` 로 복사해 채우며, .env 는 커밋되지 않는다.

# PostgreSQL
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=url_shortener

# 애플리케이션 동작 플래그
# - CACHE_ENABLED: true 면 Redis 경유 읽기 경로 활성화 (실험 1)
# - KEY_STRATEGY: base62 | hash  (실험 2)
CACHE_ENABLED=false
KEY_STRATEGY=base62
