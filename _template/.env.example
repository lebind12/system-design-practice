# 이 파일은 챕터에서 필요한 환경 변수의 "구조"를 보여주는 공개 템플릿입니다.
# 실제 값이 담긴 .env 파일은 이 파일을 복사해 만들고 커밋하지 마세요.
#
#   cp .env.example .env
#
# 챕터 README.md "환경 변수 (.env)" 섹션에 각 변수의 의미를 정리해 두세요.
# 아래는 흔히 쓰이는 변수 예시이며, 챕터마다 필요한 것만 남기고 수정하세요.

# 애플리케이션
APP_PORT=8080

# PostgreSQL (docker-compose 와 동일한 값 사용)
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=app
DATABASE_URL=postgres://app:change-me@localhost:5432/app

# Redis
REDIS_URL=redis://localhost:6379/0
